{
    "name": "nikservik/user-settings",
    "description": "User settings storage for Laravel",
    "keywords": [
        "nikservik",
        "laravel",
        "user-settings"
    ],
    "homepage": "https://github.com/nikservik/user-settings",
    "license": "MIT",
    "authors": [
        {
            "name": "Sergey Nikiforov",
            "email": "ser.nikiforov@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "ext-json": "*",
        "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "nikservik/commons": "^1.08"
    },
    "require-dev": {
        "orchestra/testbench": "^6.16|^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^9.3|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Nikservik\\UserSettings\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nikservik\\UserSettings\\Tests\\": "tests"
        }
    },
    "scripts": {
        "psalm": "vendor/bin/psalm",
        "test": "vendor/bin/phpunit",
        "testbench": "./vendor/bin/testbench package:test --no-coverage",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "ignore": [
                "PKSA-8qx3-n5y5-vvnd",
                "PKSA-w7xr-vk7n-rstm"
            ]
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nikservik\\UserSettings\\UserSettingsServiceProvider"
            ],
            "aliases": {
                "UserSettings": "Nikservik\\UserSettings\\UserSettings"
            }
        }
    },
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url" : "git@github.com:nikservik/commons"
        }
    ]
}
